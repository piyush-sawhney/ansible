# === Traefik Settings ===
TRAEFIK_CERT_RESOLVER={{ traefik_cert_resolver }}
TRAEFIK_POSTIZ_HOST={{ traefik_postiz_host }}
TRAEFIK_TEMPORAL_UI_HOST={{ traefik_temporal_ui_host }}

# === Core URLs ===
MAIN_URL={{ main_url }}
FRONTEND_URL={{ frontend_url }}
NEXT_PUBLIC_BACKEND_URL={{ next_public_backend_url }}
BACKEND_INTERNAL_URL={{ backend_internal_url | default('http://localhost:3000') }}

# === Security ===
JWT_SECRET={{ jwt_secret }}

# === PostgreSQL Main Database (Postiz) ===
DB_USER={{ postgres_user }}
DB_PASSWORD={{ postgres_password }}
DB_NAME={{ postgres_db }}

# === Temporal Database & Search Services ===
TEMPORAL_POSTGRES_USER={{ temporal_db_user }}
TEMPORAL_POSTGRES_PASSWORD={{ temporal_db_password }}
# Elasticsearch security is disabled in your compose, but kept here for future-proofing
ELASTIC_PASSWORD={{ elastic_password | default('') }}

# === Social Media API Settings ===
X_API_KEY={{ x_api_key }}
X_API_SECRET={{ x_api_secret }}
LINKEDIN_CLIENT_ID={{ linkedin_client_id }}
LINKEDIN_CLIENT_SECRET={{ linkedin_client_secret }}
FACEBOOK_APP_ID={{ facebook_app_id }}
FACEBOOK_APP_SECRET={{ facebook_app_secret }}
YOUTUBE_CLIENT_ID={{ youtube_client_id }}
YOUTUBE_CLIENT_SECRET={{ youtube_client_secret }}

# === App Configuration ===
API_LIMIT={{ api_limit | default(30) }}
NX_ADD_PLUGINS={{ nx_add_plugins | default('false') }}