# Temporal Dynamic Configuration Template
frontend.rps:
  - value: {{ temporal_frontend_rps | default(2000) }}

frontend.persistenceMaxQPS:
  - value: {{ temporal_max_persistence_qps | default(1000) }}

frontend.historyMgrNumConns:
  - value: {{ temporal_history_mgr_conns | default(20) }}

matching.persistenceMaxQPS:
  - value: {{ temporal_matching_qps | default(1000) }}

history.persistenceMaxQPS:
  - value: {{ temporal_history_qps | default(1000) }}

# Safety limits for Production
history.maximumWorkflowSize:
  - value: {{ temporal_max_workflow_size_mb | default(50) }}MB

# Cluster-wide rate limiting
frontend.namespaceRPS:
  - value: {{ temporal_namespace_rps | default(500) }}

# Visibility settings (Since you are using Elasticsearch)
system.forceSearchAttributesCacheRefreshOnRead:
  - value: false

worker.resourceMaxQPS:
  - value: {{ temporal_worker_qps | default(1000) }}

# Enable internal health checks and scanning
history.cacheInitialSize:
  - value: {{ temporal_history_cache_size | default(128) }}