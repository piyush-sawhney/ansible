global:
  sendAnonymousUsage: false

api:
  dashboard: true
  debug: false
  insecure: false

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entrypoint:
          to: websecure
          scheme: https
          permanent: true

  websecure:
    address: ":443"
    http:
      middlewares:
        - cloudflare-allow@file
      tls: {}
    forwardedHeaders:
      trustedIPs:
        - 173.245.48.0/20
        - 103.21.244.0/22
        - 103.22.200.0/22
        - 103.31.4.0/22
        - 141.101.64.0/18
        - 108.162.192.0/18
        - 190.93.240.0/20
        - 188.114.96.0/20
        - 197.234.240.0/22
        - 198.41.128.0/17
        - 162.158.0.0/15
        - 104.16.0.0/13
        - 104.24.0.0/14
        - 172.64.0.0/13
        - 131.0.72.0/22

providers:
  docker:
    exposedByDefault: false
    network: traefik-public
    endpoint: tcp://socket-proxy:2375
  file:
    filename: /config.yaml
    watch: true

certificatesResolvers:
  cloudflare:
    acme:
      caServer: {{ cloudflare_acme_server }}
      email: {{ cloudflare_email }}
      storage: acme-cf.json
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "1.1.1.1:53"
          - "1.0.0.1:53"


log:
  level: "INFO"
  filePath: "/var/log/traefik/traefik.log"
 
accessLog:
  filePath: "/var/log/traefik/access.log"
  format: json
  bufferingSize: 0
  fields: 
    headers: 
      defaultMode: drop
      names:
        user-agent: keep
  filters:
    statusCodes:
      - "400-599"

experimental:
  plugins:
    crowdsec-bouncer-traefik-plugin:
      moduleName: "github.com/maxlerebourg/crowdsec-bouncer-traefik-plugin"
      version: "{{ traefik_bouncer_version }}"